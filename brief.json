    "document_html": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Outil de Cartographie des Flux de Travail pour Artistes Indépendants | Votre Atelier Numérique</title>\n    <meta name=\"description\" content=\"Visualisez et optimisez vos processus créatifs et administratifs en tant qu\">\n    <style>\n        :root {\n            --primary-color: #7a1ba6; /* Adjusted for zine-noise vibe, bold */\n            --secondary-color: #F0F0F0;\n            --accent-color: #ff5722; /* Expressive */\n            --text-color: #333;\n            --light-text-color: #555;\n            --background-color: #fcfafa; /* Luxury neutral */\n            --card-background: #ffffff;\n            --border-radius: 8px;\n            --font-sans: 'Helvetica Neue', Arial, sans-serif; /* Soft premium sans-serif */\n        }\n        body {\n            font-family: var(--font-sans);\n            color: var(--text-color);\n            line-height: 1.6;\n            margin: 0;\n            padding: 0;\n            background: var(--background-color);\n            background: linear-gradient(135deg, var(--background-color) 0%, #e0e0e0 100%); /* Soft gradient */\n            display: flex;\n            flex-direction: column;\n            min-height: 100vh;\n        }\n        header {\n            background-color: var(--primary-color);\n            color: white;\n            padding: 2.5em 1.5em;\n            text-align: center;\n            box-shadow: 0 4px 15px rgba(0,0,0,0.1);\n        }\n        h1 {\n            font-size: 2.8em; /* Controlled scale jump */\n            margin-bottom: 0.5em;\n            font-weight: 700;\n        }\n        header p {\n            font-size: 1.2em;\n            max-width: 800px;\n            margin: 0.5em auto 0;\n            opacity: 0.9;\n        }\n        main {\n            flex-grow: 1;\n            padding: 2em 1.5em;\n            max-width: 1200px;\n            margin: 2em auto;\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 2em;\n        }\n        .card {\n            background-color: var(--card-background);\n            padding: 2em;\n            border-radius: var(--border-radius);\n            box-shadow: 0 5px 20px rgba(0,0,0,0.08); /* Tactile depth */\n            border-top: 5px solid var(--primary-color);\n            transition: transform 0.2s ease-in-out;\n        }\n        .card:hover {\n            transform: translateY(-5px);\n        }\n        .card h2 {\n            color: var(--primary-color);\n            font-size: 1.8em;\n            margin-top: 0;\n            margin-bottom: 1em;\n        }\n        label {\n            display: block;\n            margin-bottom: 0.6em;\n            font-weight: bold;\n            color: var(--light-text-color);\n        }\n        input[type=\"text\"], textarea {\n            width: calc(100% - 20px);\n            padding: 12px;\n            margin-bottom: 1.5em;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            font-size: 1em;\n            box-sizing: border-box;\n        }\n        textarea {\n            min-height: 100px;\n            resize: vertical;\n        }\n        button {\n            background-color: var(--primary-color);\n            color: white;\n            padding: 15px 25px;\n            border: none;\n            border-radius: var(--border-radius);\n            font-size: 1.1em;\n            cursor: pointer;\n            transition: background-color 0.3s ease, transform 0.1s ease;\n            display: block;\n            width: fit-content;\n            margin-top: 1.5em;\n        }\n        button:hover {\n            background-color: #6a1892; /* Slightly darker primary */\n            transform: translateY(-2px);\n        }\n        #tool-result {\n            background-color: var(--card-background);\n            padding: 2em;\n            border-radius: var(--border-radius);\n            box-shadow: 0 5px 20px rgba(0,0,0,0.08);\n            border-top: 5px solid var(--accent-color);\n            margin-top: 2em;\n            grid-column: 1 / -1; /* Spans full width */\n            display: none; /* Hidden until results are ready */\n        }\n        #tool-result h3 {\n            color: var(--accent-color);\n            font-size: 1.6em;\n            margin-bottom: 1em;\n        }\n        #tool-result div {\n            margin-bottom: 1.5em;\n            border-bottom: 1px dashed #eee;\n            padding-bottom: 1.5em;\n        }\n        #tool-result div:last-child {\n            border-bottom: none;\n            padding-bottom: 0;\n        }\n        #tool-result ul {\n            list-style: none;\n            padding: 0;\n            margin-top: 0.8em;\n        }\n        #tool-result li {\n            background-color: #f9f9f9;\n            padding: 10px 15px;\n            border-left: 4px solid var(--primary-color);\n            margin-bottom: 8px;\n            border-radius: 4px;\n            font-size: 0.95em;\n            word-wrap: break-word;\n        }\n        .section-title {\n            color: var(--primary-color);\n            font-size: 2em;\n            text-align: center;\n            margin: 2em 0 1em;\n            font-weight: 700;\n        }\n        .info-panel {\n            background-color: var(--card-background);\n            padding: 2em;\n            border-radius: var(--border-radius);\n            box-shadow: 0 5px 20px rgba(0,0,0,0.08);\n            border-top: 5px solid #a821bd; /* Unique color from design seed */\n        }\n        .info-panel h3 {\n            color: #a821bd;\n            font-size: 1.5em;\n            margin-top: 0;\n        }\n        .info-panel p {\n            color: var(--light-text-color);\n            font-size: 0.95em;\n        }\n        footer {\n            background-color: var(--text-color);\n            color: white;\n            text-align: center;\n            padding: 3em 1.5em;\n            margin-top: 4em;\n            font-size: 0.9em;\n            box-shadow: 0 -4px 15px rgba(0,0,0,0.05);\n        }\n        footer h3 {\n            color: var(--secondary-color);\n            margin-bottom: 1em;\n            font-size: 1.4em;\n        }\n        footer p {\n            max-width: 900px;\n            margin: 1em auto;\n            line-height: 1.8;\n            opacity: 0.9;\n        }\n        footer a {\n            color: var(--accent-color);\n            text-decoration: none;\n            transition: color 0.3s ease;\n        }\n        footer a:hover {\n            color: #ff8c00;\n        }\n\n        /* Responsive adjustments */\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2em;\n            }\n            header p {\n                font-size: 1em;\n            }\n            main {\n                grid-template-columns: 1fr;\n                padding: 1.5em;\n                margin: 1.5em auto;\n            }\n            .card {\n                padding: 1.5em;\n            }\n            .card h2 {\n                font-size: 1.5em;\n            }\n            input[type=\"text\"], textarea {\n                width: 100%;\n            }\n            button {\n                width: 100%;\n                text-align: center;\n            }\n            .section-title {\n                font-size: 1.7em;\n            }\n        }\n    </style>\n    <meta name=\"robots\" content=\"index, follow\">\n    <link rel=\"canonical\" href=\"https://outil-de-cartographie-des-flux-de-travail-pour-49f45fde.onrender.com\">\n    <meta property=\"og:title\" content=\"Outil de Cartographie des Flux de Travail pour Artistes Indépendants\">\n    <meta property=\"og:description\" content=\"Visualisez et optimisez vos processus créatifs et administratifs en tant qu\">\n    <meta property=\"og:url\" content=\"https://outil-de-cartographie-des-flux-de-travail-pour-49f45fde.onrender.com\">\n    <meta property=\"og:type\" content=\"website\">\n    <script type=\"application/ld+json\">{\"@context\": \"https://schema.org\", \"@type\": \"WebApplication\", \"name\": \"Outil de Cartographie des Flux de Travail pour Artistes Indépendants\", \"description\": \"Visualisez et optimisez vos processus créatifs et administratifs en tant qu\", \"url\": \"https://outil-de-cartographie-des-flux-de-travail-pour-49f45fde.onrender.com\", \"applicationCategory\": \"UtilityApplication\", \"operatingSystem\": \"Web Browser\"}</script>\n</head>\n<body data-site-slug=\"outil-de-cartographie-des-flux-de-travail-pour-49f45fde\" data-runtime-mode=\"analysis_tool\">\n    <header>\n        <h1>Outil de Cartographie des Flux de Travail pour Artistes Indépendants</h1>\n        <p>Visualisez et optimisez vos processus créatifs et administratifs. Identifiez les goulets d'étranglement, gagnez du temps et libérez votre potentiel artistique.</p>\n    </header>\n\n    <main>\n        <div class=\"card\">\n            <h2>Votre Atelier Numérique</h2>\n            <p>Décrivez votre processus. De l'idée à la vente, chaque étape compte. Plus vous êtes précis, plus nos suggestions seront pertinentes.</p>\n            <form id=\"tool-form\">\n                <label for=\"artiste-domaine\">Votre domaine artistique principal :</label>\n                <input type=\"text\" id=\"artiste-domaine\" placeholder=\"Ex: Peinture, Sculpture, Musique, Photographie...\" required>\n\n                <label for=\"processus-creatif\">Décrivez les grandes étapes de votre processus créatif (séparées par des virgules) :</label>\n                <textarea id=\"processus-creatif\" placeholder=\"Ex: Idéation, Esquisse, Production, Finition, Documentation...\" required></textarea>\n\n                <label for=\"processus-administratif\">Décrivez vos tâches administratives ou de vente (séparées par des virgules) :</label>\n                <textarea id=\"processus-administratif\" placeholder=\"Ex: Communication client, Facturation, Marketing, Gestion des stocks, Expédition...\" required></textarea>\n\n                <label for=\"defis\">Quels sont vos principaux défis actuels ? (optionnel)</label>\n                <input type=\"text\" id=\"defis\" placeholder=\"Ex: Manque de temps pour le marketing, difficultés à fixer les prix...\">\n                \n                <button type=\"submit\" id=\"tool-submit\">Cartographier Mon Flux</button>\n            </form>\n        </div>\n\n        <div class=\"info-panel\">\n            <h3>Pourquoi cartographier votre flux ?</h3>\n            <p>En tant qu'artiste indépendant, jongler entre la création et la gestion est un art en soi. Notre outil vous aide à mettre en lumière chaque étape de votre parcours, identifiant les moments clés et les points faibles où l'énergie ou le temps est perdu. C'est le premier pas vers une efficacité accrue et plus de temps pour ce que vous aimez faire : créer.</p>\n            <p>Imaginez un processus fluide, moins de stress et plus de ventes. C'est à portée de main.</p>\n            <button data-affiliate-slot=\"premium-guide\">Découvrir les bonnes pratiques</button>\n        </div>\n        \n        <div id=\"tool-result\">\n            <h3 id=\"result-headline\">Votre Cartographie Personnalisée : Suggestions & Optimisations</h3>\n            <p>Voici une visualisation simplifiée de votre flux de travail et des pistes pour l'améliorer.</p>\n\n            <div id=\"result-flux-creatif\">\n                <h4>Flux Créatif Suggéré</h4>\n                <ul></ul>\n            </div>\n\n            <div id=\"result-flux-administratif\">\n                <h4>Flux Administratif & Commercial Suggéré</h4>\n                <ul></ul>\n            </div>\n\n            <div id=\"result-optimisations\">\n                <h4>Pistes d'Optimisation Générales</h4>\n                <ul></ul>\n            </div>\n        </div>\n    </main>\n\n    <footer>\n        <h3>Artistes, Libérez Votre Temps Précieux</h3>\n        <p>Dans un monde où chaque artiste doit être un entrepreneur, la gestion efficace de son temps et de ses ressources est primordiale. Cet outil est conçu pour les créateurs français, qu'ils soient peintres, sculpteurs, musiciens, photographes ou artisans d'art. Que vous cherchiez à optimiser votre <a href=\"#seo-flux-creatif\">processus créatif</a>, à améliorer votre <a href=\"#seo-gestion-administrative-artiste\">gestion administrative</a>, ou à mieux organiser votre <a href=\"#seo-vente-oeuvres-art\">vente d'œuvres d'art</a>, notre plateforme vous offre une vision claire et des solutions concrètes.</p>\n        <p>Découvrez comment structurer votre <a href=\"#seo-workflow-artiste\">workflow d'artiste</a>, identifier les goulets d'étranglement et maximiser votre productivité. Pour les artistes indépendants en France, l'efficacité est la clé du succès et de l'épanouissement. Un outil simple pour des résultats concrets, pensé pour vous et votre art.</p>\n        <p>&copy; 2023 Tous droits réservés.</p>\n    </footer>\n\n    <script>\n        document.getElementById('tool-form').addEventListener('submit', function(event) {\n            event.preventDefault();\n\n            const domaine = document.getElementById('artiste-domaine').value.trim();\n            const creatifInput = document.getElementById('processus-creatif').value.trim();\n            const administratifInput = document.getElementById('processus-administratif').value.trim();\n            const defis = document.getElementById('defis').value.trim();\n\n            const processusCreatif = creatifInput.split(',').map(s => s.trim()).filter(s => s.length > 0);\n            const processusAdministratif = administratifInput.split(',').map(s => s.trim()).filter(s => s.length > 0);\n\n            const resultCreatifUl = document.querySelector('#result-flux-creatif ul');\n            const resultAdministratifUl = document.querySelector('#result-flux-administratif ul');\n            const resultOptimisationsUl = document.querySelector('#result-optimisations ul');\n\n            resultCreatifUl.innerHTML = '';\n            resultAdministratifUl.innerHTML = '';\n            resultOptimisationsUl.innerHTML = '';\n\n            // Generate Creative Flow\n            const baseCreativeSteps = ['Idée / Inspiration', 'Recherche / Planification', 'Ébauche / Première version', 'Production / Réalisation', 'Détails / Finition', 'Critique / Auto-évaluation', 'Documentation (photos, notes)'];\n            processusCreatif.forEach(step => {\n                const li = document.createElement('li');\n                li.textContent = step;\n                resultCreatifUl.appendChild(li);\n            });\n            baseCreativeSteps.filter(step => !processusCreatif.includes(step)).forEach(step => {\n                const li = document.createElement('li');\n                li.textContent = step + ' (à considérer)';\n                li.style.fontStyle = 'italic';\n                li.style.color = '#777';\n                resultCreatifUl.appendChild(li);\n            });\n\n            // Generate Administrative Flow\n            const baseAdminSteps = ['Communication initiale', 'Établissement du devis', 'Contrat (si applicable)', 'Suivi de production', 'Facturation', 'Paiement', 'Expédition / Livraison', 'Communication post-vente'];\n            processusAdministratif.forEach(step => {\n                const li = document.createElement('li');\n                li.textContent = step;\n                resultAdministratifUl.appendChild(li);\n            });\n            baseAdminSteps.filter(step => !processusAdministratif.includes(step)).forEach(step => {\n                const li = document.createElement('li');\n                li.textContent = step + ' (à ne pas oublier)';\n                li.style.fontStyle = 'italic';\n                li.style.color = '#777';\n                resultAdministratifUl.appendChild(li);\n            });\n\n            // Generate Optimizations\n            const optimisations = [];\n\n            // Based on domain\n            if (domaine.toLowerCase().includes('peinture') || domaine.toLowerCase().includes('sculpture')) {\n                optimisations.push(\"Considérez la gestion de l'inventaire de vos matériaux et œuvres.\");\n                optimisations.push(\"Pensez à des techniques de séchage ou de conservation pour optimiser l'espace et le temps.\");\n            } else if (domaine.toLowerCase().includes('musique')) {\n                optimisations.push(\"Explorez des outils de gestion de projet pour vos compositions et enregistrements.\");\n                optimisations.push(\"Automatisez la distribution de votre musique sur les plateformes.\");\n            } else if (domaine.toLowerCase().includes('photographie')) {\n                optimisations.push(\"Mettez en place un système de sauvegarde et d'organisation pour vos fichiers RAW.\");\n                optimisations.push(\"Utilisez des presets pour accélérer votre post-traitement.\");\n            }\n\n            // General optimizations\n            if (processusCreatif.length < 4) {\n                optimisations.push(\"Détaillez davantage vos étapes créatives pour mieux visualiser les phases distinctes.\");\n            }\n            if (processusAdministratif.length < 4) {\n                optimisations.push(\"Pensez à inclure le marketing et le suivi client comme des étapes à part entière.\");\n            }\n            if (creatifInput.includes('documentation') && !administratifInput.includes('marketing')) {\n                optimisations.push(\"Exploitez votre documentation créative pour vos efforts marketing sur les réseaux sociaux.\");\n            }\n            if (administratifInput.includes('facturation') && !administratifInput.includes('devis')) {\n                optimisations.push(\"Assurez-vous de bien formaliser vos devis avant la facturation pour éviter les malentendus.\");\n            }\n            if (defis.toLowerCase().includes('temps marketing') || defis.toLowerCase().includes('promotion')) {\n                optimisations.push(\"Dédiez des créneaux fixes pour le marketing chaque semaine et explorez des outils de planification de contenu.\");\n            }\n            if (defis.toLowerCase().includes('prix') || defis.toLowerCase().includes('rémunération')) {\n                optimisations.push(\"Faites une étude de marché pour vos prix et prenez en compte tous vos coûts (matériaux, temps, charges).\");\n            }\n            if (processusAdministratif.includes('expédition')) {\n                optimisations.push(\"Recherchez des solutions logistiques pour artistes, optimisant coûts et sécurité pour vos envois.\");\n            }\n\n            // Fallback if no specific optimizations\n            if (optimisations.length === 0) {\n                optimisations.push(\"Toutes les étapes semblent bien intégrées ! Continuez d'analyser chaque point pour des gains marginaux.\");\n                optimisations.push(\"Envisagez d'utiliser des outils de gestion de projet pour suivre l'avancement de vos œuvres.\");\n            }\n\n            optimisations.forEach(opt => {\n                const li = document.createElement('li');\n                li.textContent = opt;\n                resultOptimisationsUl.appendChild(li);\n            });\n\n            document.getElementById('tool-result').style.display = 'block';\n            window.scrollTo({\n                top: document.getElementById('tool-result').offsetTop - 50,\n                behavior: 'smooth'\n            });\n        });\n    </script>\n<div id=\"qa-smoke-result\" hidden></div>\n<script id=\"farmbuilder-affiliate-helper\">\n(function () {\n  window.__UTILITY_AFFILIATE_MAP = window.__UTILITY_AFFILIATE_MAP || {};\n  document.addEventListener(\"click\", function (event) {\n    const target = event.target.closest(\"[data-affiliate-slot]\");\n    if (!target) return;\n    const slot = target.getAttribute(\"data-affiliate-slot\");\n    const href = window.__UTILITY_AFFILIATE_MAP[slot];\n    if (!href) return;\n    if (target.tagName && target.tagName.toLowerCase() === \"a\") {\n      target.setAttribute(\"href\", href);\n      target.removeAttribute(\"rel\");\n      return;\n    }\n    event.preventDefault();\n    window.open(href, \"_blank\");\n  }, true);\n})();\n</script>\n<script id=\"farmbuilder-functional-qa\">\n(function () {\n  function marker() {\n    let node = document.getElementById(\"qa-smoke-result\");\n    if (node) return node;\n    node = document.createElement(\"div\");\n    node.id = \"qa-smoke-result\";\n    node.hidden = true;\n    document.body.appendChild(node);\n    return node;\n  }\n\n  let qaFinished = false;\n  let qaWatchdog = null;\n\n  function normalize(text) {\n    return String(text || \"\").replace(/\\s+/g, \" \").trim();\n  }\n\n  function findForm() {\n    return document.getElementById(\"tool-form\") || document.querySelector(\"form\");\n  }\n\n  function findResult() {\n    return (\n      document.getElementById(\"tool-result\") ||\n      document.querySelector(\"[data-result]\") ||\n      document.querySelector(\".tool-result, .result-card, .result, .results, .output, .preview, .diagnostic, .analysis\")\n    );\n  }\n\n  function primaryAction(form) {\n    if (!form) return null;\n    return (\n      document.getElementById(\"tool-submit\") ||\n      form.querySelector(\"#tool-submit\") ||\n      form.querySelector(\"[data-primary-action]\") ||\n      form.querySelector(\"button[type=submit]\") ||\n      form.querySelector(\"button\") ||\n      form.querySelector(\"input[type=submit]\")\n    );\n  }\n\n  function resultSignature(node) {\n    if (!node) return \"\";\n    const text = normalize(node.textContent);\n    const html = normalize(node.innerHTML).slice(0, 600);\n    return `${text}||${html}`;\n  }\n\n  function resultHeadline(node) {\n    if (!node) return \"\";\n    const heading = node.querySelector(\"h1, h2, h3, strong, b\");\n    return normalize(heading ? heading.textContent : \"\");\n  }\n\n  function sampleText(field) {\n    const key = `${field.id || \"\"} ${field.name || \"\"} ${field.placeholder || \"\"}`.toLowerCase();\n    if (/email/.test(key)) return \"bonjour@example.com\";\n    if (/url|site|website|lien/.test(key)) return \"https://example.com/offre-solaire\";\n    if (/phone|tel|mobile/.test(key)) return \"0612345678\";\n    if (/ville|city|localisation|location|region|departement|postal/.test(key)) return \"Paris\";\n    if (/orientation/.test(key)) return \"sud\";\n    if (/keyword|theme|topic|sujet|subject/.test(key)) return \"energie solaire domestique\";\n    if (/titre|title/.test(key)) return \"Simulateur solaire maison\";\n    if (/nom|name|project/.test(key)) return \"Projet Horizon\";\n    if (/description|notes|content|message/.test(key)) return \"Maison individuelle exposee sud avec toiture exploitable.\";\n    return field.placeholder || \"France\";\n  }\n\n  function sampleNumber(field) {\n    const key = `${field.id || \"\"} ${field.name || \"\"}`.toLowerCase();\n    if (/inclinaison|angle|slope/.test(key)) return \"30\";\n    if (/surface|size|m2|sqm/.test(key)) return \"28\";\n    if (/annee|year/.test(key)) return \"2024\";\n    if (/prix|price|budget|cost|amount|montant/.test(key)) return \"12000\";\n    const min = Number(field.min || \"\");\n    const max = Number(field.max || \"\");\n    if (Number.isFinite(min) && Number.isFinite(max) && max >= min) {\n      return String(Math.min(max, Math.max(min, min + Math.round((max - min) * 0.35))));\n    }\n    if (Number.isFinite(min)) return String(Math.max(min, 12));\n    if (Number.isFinite(max)) return String(Math.min(max, 12));\n    return field.value || \"12\";\n  }\n\n  function applySample(field) {\n    const tag = (field.tagName || \"\").toLowerCase();\n    const type = (field.type || \"\").toLowerCase();\n    if (field.disabled) return;\n    if (type === \"hidden\" || type === \"submit\" || type === \"button\" || type === \"reset\" || type === \"image\" || type === \"file\") {\n      return;\n    }\n    const currentValue = normalize(field.value);\n    if (tag === \"select\") {\n      if (currentValue) return;\n      const option = Array.from(field.options || []).find((item) => item.value && !item.disabled) || field.options[0];\n      if (option) field.value = option.value;\n      return;\n    }\n    if (type === \"checkbox\") {\n      if (field.checked) return;\n      field.checked = true;\n      return;\n    }\n    if (type === \"radio\") {\n      if (field.checked) return;\n      field.checked = true;\n      return;\n    }\n    if (type === \"date\") {\n      if (currentValue) return;\n      field.value = \"2026-03-01\";\n      return;\n    }\n    if (type === \"email\") {\n      if (currentValue) return;\n      field.value = \"bonjour@example.com\";\n      return;\n    }\n    if (type === \"url\") {\n      if (currentValue) return;\n      field.value = \"https://example.com/offre-solaire\";\n      return;\n    }\n    if (type === \"tel\") {\n      if (currentValue) return;\n      field.value = \"0612345678\";\n      return;\n    }\n    if (type === \"color\") {\n      if (currentValue) return;\n      field.value = \"#2f855a\";\n      return;\n    }\n    if (type === \"number\" || type === \"range\") {\n      if (currentValue) return;\n      field.value = sampleNumber(field);\n      return;\n    }\n    if (currentValue) return;\n    field.value = sampleText(field);\n  }\n\n  function stamp(status, detail, headline, primary) {\n    if (qaFinished) return;\n    qaFinished = true;\n    if (qaWatchdog) {\n      window.clearTimeout(qaWatchdog);\n      qaWatchdog = null;\n    }\n    const node = marker();\n    node.dataset.status = status;\n    node.dataset.mode = \"native-form\";\n    node.dataset.detail = detail || \"\";\n    node.dataset.headline = headline || \"\";\n    node.dataset.primary = primary || \"\";\n    node.dataset.viewport = window.innerWidth <= 640 ? \"mobile\" : \"desktop\";\n    window.setTimeout(function () {\n      try {\n        window.stop();\n      } catch (_error) {}\n    }, 0);\n  }\n\n  function installModalGuards() {\n    const noop = function () {};\n    const approve = function () { return true; };\n    const empty = function () { return \"\"; };\n    try { window.alert = noop; } catch (_error) {}\n    try { window.confirm = approve; } catch (_error) {}\n    try { window.prompt = empty; } catch (_error) {}\n  }\n\n  function triggerAction(form, action) {\n    try {\n      if (typeof form.requestSubmit === \"function\") {\n        form.requestSubmit(action || undefined);\n        return;\n      }\n    } catch (_error) {}\n    if (action && typeof action.click === \"function\") {\n      action.click();\n      return;\n    }\n    form.dispatchEvent(new Event(\"submit\", { bubbles: true, cancelable: true }));\n  }\n\n  function inspectResult(before, attemptsLeft) {\n    const result = findResult();\n    if (!result) {\n      stamp(\"fail\", \"La zone de resultat est introuvable.\", \"\");\n      return;\n    }\n    const after = resultSignature(result);\n    const text = normalize(result.textContent);\n    if (after && after !== before && text.length >= 24) {\n      const primary = result.querySelector(\"a[href], button[data-href], [data-primary-url]\") || document.querySelector(\"#tool-result a[href]\");\n      stamp(\"pass\", \"Le formulaire natif a mis a jour la zone de resultat.\", resultHeadline(result), primary ? (primary.getAttribute(\"href\") || primary.getAttribute(\"data-primary-url\") || \"\") : \"\");\n      return;\n    }\n    if (attemptsLeft > 0) {\n      window.setTimeout(function () {\n        inspectResult(before, attemptsLeft - 1);\n      }, 250);\n      return;\n    }\n    stamp(\"fail\", \"La zone de resultat n'a pas renvoye de contenu exploitable.\", resultHeadline(result));\n  }\n\n  function runSmoke() {\n    const params = new URLSearchParams(window.location.search);\n    if (params.get(\"__qa\") !== \"functional\") return;\n    qaWatchdog = window.setTimeout(function () {\n      stamp(\"fail\", \"QA smoke timed out before the page reported a usable result.\", \"\");\n    }, 7000);\n    const form = findForm();\n    if (!form) {\n      stamp(\"fail\", \"Le formulaire principal est introuvable.\", \"\");\n      return;\n    }\n    const result = findResult();\n    const before = resultSignature(result);\n    installModalGuards();\n    try {\n      form.querySelectorAll(\"input, select, textarea\").forEach(applySample);\n    } catch (error) {\n      stamp(\"fail\", error && error.message ? `QA smoke sample failed: ${error.message}` : \"QA smoke sample failed before submit.\", \"\");\n      return;\n    }\n    const action = primaryAction(form);\n    try {\n      triggerAction(form, action);\n    } catch (error) {\n      stamp(\"fail\", error && error.message ? `QA smoke submit failed: ${error.message}` : \"QA smoke submit failed.\", \"\");\n      return;\n    }\n    inspectResult(before, 10);\n  }\n\n  window.addEventListener(\"error\", function (event) {\n    const message = event && event.message ? event.message : \"JavaScript runtime error during QA smoke.\";\n    stamp(\"fail\", `QA smoke JS error: ${message}`, \"\");\n  }, { once: true });\n\n  window.addEventListener(\"unhandledrejection\", function (event) {\n    const reason = event && event.reason;\n    const detail = typeof reason === \"string\"\n      ? reason\n      : reason && reason.message\n        ? reason.message\n        : \"Unhandled promise rejection during QA smoke.\";\n    stamp(\"fail\", `QA smoke rejection: ${detail}`, \"\");\n  }, { once: true });\n\n  if (document.readyState === \"loading\") {\n    document.addEventListener(\"DOMContentLoaded\", function () {\n      window.setTimeout(runSmoke, 60);\n    }, { once: true });\n  } else {\n    window.setTimeout(runSmoke, 60);\n  }\n})();\n</script>\n</body>\n</html>",
